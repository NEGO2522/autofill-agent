{
  "manifest_version": 3,
  "name": "AutoSlay - AI Autofill Agent",
  "version": "1.0.0",
  "description": "AI-powered form automation. Fill any web form instantly.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": ["<all_urls>"]
}
