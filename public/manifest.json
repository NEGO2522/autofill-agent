{
  "manifest_version": 3,
  "name": "AutoSlay Agent",
  "version": "1.1.0",
  "description": "Smart form autofill agent — fill any form in one click using your saved profile.",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": ["https://*/*", "http://*/*"],
  "action": {
    "default_popup": "index.html",
    "default_title": "AutoSlay Agent"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  }
}
